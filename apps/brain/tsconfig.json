{
  "extends": "@repo/typescript-config/base.json",
  "compilerOptions": {
    "module": "esnext",
    "moduleResolution": "bundler",
    "paths": {
      "@shadowbox/execution-engine/runtime": [
        "../../packages/execution-engine/src/runtime/index.ts"
      ],
      "@shadowbox/execution-engine/runtime/*": [
        "../../packages/execution-engine/src/runtime/*"
      ],
      "@repo/shared-types": ["../../packages/shared-types/src/index.ts"],
      "@repo/shared-types/*": ["../../packages/shared-types/src/*"]
    },
    "types": ["@cloudflare/workers-types", "@types/node"],
    "noEmit": true,
    "strict": true,
    "skipLibCheck": true
  },
  "include": ["src/**/*.ts", "worker-configuration.d.ts"],
  "exclude": ["node_modules", "src/**/*.test.ts"]
}
