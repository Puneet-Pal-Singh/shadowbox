# Brain local development env example.

# GitHub auth + session (required)
GITHUB_CLIENT_ID=your-github-client-id
GITHUB_CLIENT_SECRET=your-github-client-secret
GITHUB_REDIRECT_URI=http://localhost:8788/auth/github/callback
GITHUB_TOKEN_ENCRYPTION_KEY=your-random-token-encryption-key
SESSION_SECRET=your-random-session-secret
FRONTEND_URL=http://localhost:5173

# BYOK credential encryption (required for provider setup/chat)
# Generate with: openssl rand -hex 32
BYOK_CREDENTIAL_ENCRYPTION_KEY=your-random-64-char-hex-key
BYOK_CREDENTIAL_ENCRYPTION_KEY_VERSION=v1

# Local secure-agent-api endpoint (required in local dev)
MUSCLE_BASE_URL=http://localhost:8787

# Optional
# CORS_ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
# CORS_ALLOW_DEV_ORIGINS=true
