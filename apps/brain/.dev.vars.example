# Brain Local Development Configuration
# Copy this file to .dev.vars and fill in required values.

# Keep this file minimal: only critical env vars.
# Provider API keys are optional and not required for baseline chat startup.

# Optional custom system prompt
SYSTEM_PROMPT="You are Shadowbox, an autonomous expert software engineer. Work in /home/sandbox/workspaces/${runId}. Answer directly without over-engineering or unnecessary tool use. Use tools ONLY if explicitly asked. Be concise."

# -----------------------------------------------------------------------------
# Default Chat Fallback (recommended)
# -----------------------------------------------------------------------------
# Used when no BYOK provider is connected.
OPENROUTER_API_KEY=your-openrouter-api-key
DEFAULT_MODEL=arcee-ai/trinity-large-preview:free

# -----------------------------------------------------------------------------
# GitHub Auth + Session (required for GitHub integration)
# -----------------------------------------------------------------------------
GITHUB_CLIENT_ID=your-github-client-id
GITHUB_CLIENT_SECRET=your-github-client-secret
GITHUB_REDIRECT_URI=http://localhost:8788/auth/github/callback
# 20+ char random hex/string
GITHUB_TOKEN_ENCRYPTION_KEY=your-random-token-encryption-key
# 12+ char random hex/string
SESSION_SECRET=your-random-session-secret
FRONTEND_URL=http://localhost:5173

# CORS controls (optional)
# Comma-separated origins; FRONTEND_URL is always included automatically.
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
CORS_ALLOW_DEV_ORIGINS=true

# -----------------------------------------------------------------------------
# BYOK Credential Encryption (required for BYOK routes)
# -----------------------------------------------------------------------------
# Generate with: openssl rand -hex 32
BYOK_CREDENTIAL_ENCRYPTION_KEY=your-random-64-char-hex-key
BYOK_CREDENTIAL_ENCRYPTION_KEY_VERSION=v1

# Optional key rotation
# BYOK_CREDENTIAL_ENCRYPTION_KEY_PREVIOUS=your-previous-64-char-hex-key
# BYOK_CREDENTIAL_ENCRYPTION_KEY_PREVIOUS_VERSION=v0

# Optional service URL override (mainly production/staging)
# MUSCLE_BASE_URL=http://localhost:8787
# NODE_ENV=development
